name: US Market Crash Monitor

on:
  schedule:
    # GitHub 伺服器使用 UTC 時間。台灣時間 23:00 = UTC 15:00
    # 1-5 代表星期一到星期五 (涵蓋美股主要交易日)
    - cron: '0 15 * * 1-5'
  
  # 加入 workflow_dispatch 允許您隨時在 GitHub 網頁上手動點擊測試
  workflow_dispatch: 

jobs:
  run-monitor:
    runs-on: ubuntu-latest
    
    # 強制將 Ubuntu 伺服器的時區改為台灣時間，確保 Email 內文顯示的時間是正確的
    env:
      TZ: Asia/Taipei 

    steps:
    # 1. 抓取您的程式碼
    - name: Checkout Repository
      uses: actions/checkout@v3

    # 2. 建立 Python 環境
    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.11'

    # 3. 安裝必要的套件 (yfinance)
    - name: Install Dependencies
      run: |
        python -m pip install --upgrade pip
        pip install yfinance

    # 4. 執行您的避險監控程式
    - name: Run buyput script
      env:
        # 將 GitHub Secrets 注入為環境變數，供 Python 讀取
        STOCK_BOT_EMAIL: ${{ secrets.STOCK_BOT_EMAIL }}
        STOCK_BOT_PWD: ${{ secrets.STOCK_BOT_PWD }}
      run: python buyput.py
